# Environment Variables Configuration
# Copy this file to .env and modify as needed

# Camera Configuration
CAMERA_ID=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Calibration Configuration
CALIBRATION_FILE=camera_calibration.pkl
CHECKERBOARD_WIDTH=9
CHECKERBOARD_HEIGHT=6
SQUARE_SIZE_MM=25.0

# ArUco Configuration
ARUCO_DICTIONARY=DICT_4X4_50
MARKER_SIZE_MM=50.0

# Pose Estimation Configuration
POSE_ALGORITHM=SOLVEPNP_EPNP
USE_RANSAC=true
TEMPORAL_FILTERING=true
FILTER_ALPHA=0.3

# Visualization Configuration
SHOW_AXES=true
SHOW_CUBE=true
SHOW_TRAJECTORY=true
SHOW_INFO=true

# Output Configuration
OUTPUT_DIRECTORY=output
SAVE_FRAMES=false
SAVE_TRAJECTORY=true

# Performance Configuration
ENABLE_THREADING=true
MAX_PROCESSING_TIME=0.033

# Robustness Configuration
KALMAN_PROCESS_NOISE_POS=1.0
KALMAN_PROCESS_NOISE_ROT=0.1
KALMAN_MEASUREMENT_NOISE_POS=5.0
KALMAN_MEASUREMENT_NOISE_ROT=0.5

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=visionpose6d.log
