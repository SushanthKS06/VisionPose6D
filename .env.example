CAMERA_ID=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

CALIBRATION_FILE=camera_calibration.pkl
CHECKERBOARD_WIDTH=9
CHECKERBOARD_HEIGHT=6
SQUARE_SIZE_MM=25.0

ARUCO_DICTIONARY=DICT_4X4_50
MARKER_SIZE_MM=50.0

POSE_ALGORITHM=SOLVEPNP_EPNP
USE_RANSAC=true
TEMPORAL_FILTERING=true
FILTER_ALPHA=0.3

SHOW_AXES=true
SHOW_CUBE=true
SHOW_TRAJECTORY=true
SHOW_INFO=true

OUTPUT_DIRECTORY=output
SAVE_FRAMES=false
SAVE_TRAJECTORY=true

ENABLE_THREADING=true
MAX_PROCESSING_TIME=0.033

KALMAN_PROCESS_NOISE_POS=1.0
KALMAN_PROCESS_NOISE_ROT=0.1
KALMAN_MEASUREMENT_NOISE_POS=5.0
KALMAN_MEASUREMENT_NOISE_ROT=0.5

LOG_LEVEL=INFO
LOG_FILE=visionpose6d.log
